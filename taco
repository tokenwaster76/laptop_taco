#!/usr/bin/env bash
# Laptop Taco 🌮 — keep your Mac awake while your agent cooks.
# https://github.com/tokenwaster76/laptop_taco

set -u
set -o pipefail

VERSION="0.1.0"

print_help() {
  cat <<'EOF'
🌮 Laptop Taco — for when your agent is cooking and you need to catch a bus.

USAGE
  taco <command...>
  taco "<quoted command with shell features>"
  taco doctor
  taco --help | --version

EXAMPLES
  taco claude
  taco codex
  taco opencode
  taco "npm test"
  taco "echo cooking && sleep 3 && echo done"
  taco doctor

WHAT IT DOES
  Wraps your command in macOS caffeinate so the system stays awake
  while it runs. Prints PID and battery. Notifies when it's done.
  Returns the same exit code as the wrapped command.

  Run 'taco doctor' to verify your macOS setup is wired up correctly.

SAFETY
  Do not put a hot running laptop in a backpack. Seriously.
  Close the taco with Ctrl+C.

macOS-only. No deps. No cloud. No account.
EOF
}

if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
  print_help
  exit 0
fi

if [[ "${1:-}" == "--version" || "${1:-}" == "-v" ]]; then
  echo "taco ${VERSION}"
  exit 0
fi

run_doctor() {
  local fail=0 warn=0 tool raw
  echo "🌮 Laptop Taco ${VERSION} — doctor"
  echo
  echo "Platform:    $(uname -srm)"
  if [[ "$(uname)" == "Darwin" ]]; then
    echo "macOS:       $(sw_vers -productVersion 2>/dev/null || echo unknown)"
  else
    echo "✗ Not Darwin — taco will not run on this platform"
    fail=$((fail + 1))
  fi
  echo "Bash:        ${BASH_VERSION}"
  echo
  for tool in /usr/bin/caffeinate /usr/bin/pmset /usr/bin/osascript; do
    if [[ -x "$tool" ]]; then
      echo "✓ ${tool}"
    else
      echo "✗ ${tool}  (missing)"
      fail=$((fail + 1))
    fi
  done
  echo
  if command -v pmset >/dev/null 2>&1; then
    raw="$(pmset -g batt 2>/dev/null | grep -Eo '[0-9]+%' | head -1 || true)"
    raw="${raw%\%}"
    if [[ "$raw" =~ ^[0-9]+$ ]]; then
      echo "Battery:     ${raw}%"
      if (( raw < 20 )); then
        echo "⚠ Battery below 20% — plug in before long runs."
        warn=$((warn + 1))
      fi
    else
      echo "Battery:     no battery reported (desktop Mac?)"
    fi
  fi
  echo
  echo "Notifications: cannot verify without firing one. Try:  ./taco \"sleep 1\""
  echo "If no banner appears, check System Settings → Notifications."
  echo
  if (( fail > 0 )); then
    echo "Verdict: ${fail} blocker(s) — fix before running taco"
    return 1
  fi
  if (( warn > 0 )); then
    echo "Verdict: ready (${warn} warning(s))"
  else
    echo "Verdict: ready"
  fi
  return 0
}

if [[ "${1:-}" == "doctor" ]]; then
  run_doctor
  exit $?
fi

if [[ "$(uname)" != "Darwin" ]]; then
  echo "🌮 Laptop Taco is macOS-only. This taco only folds on Darwin." >&2
  exit 1
fi

if [[ ! -x /usr/bin/caffeinate ]]; then
  echo "🌮 /usr/bin/caffeinate not found. Is this actually macOS?" >&2
  exit 1
fi

if [[ $# -lt 1 ]]; then
  echo "🌮 No command given. Try: taco claude" >&2
  echo "   See: taco --help" >&2
  exit 1
fi

command_str="$*"

battery_pct=""
if command -v pmset >/dev/null 2>&1; then
  raw="$(pmset -g batt 2>/dev/null | grep -Eo '[0-9]+%' | head -1 || true)"
  raw="${raw%\%}"
  if [[ "$raw" =~ ^[0-9]+$ ]]; then
    battery_pct="$raw"
  fi
fi

start_epoch="$(date +%s)"
start_clock="$(date +%H:%M:%S)"

child_pid=""
caffeinate_pid=""
child_kill_target=""

cleanup_caffeinate() {
  if [[ -n "${caffeinate_pid:-}" ]]; then
    kill "$caffeinate_pid" 2>/dev/null || true
    wait "$caffeinate_pid" 2>/dev/null || true
    caffeinate_pid=""
  fi
}

cleanup_child() {
  local kill_target
  if [[ -z "${child_pid:-}" ]]; then
    return
  fi
  kill_target="${child_kill_target:-$child_pid}"
  if kill -0 "$child_pid" 2>/dev/null; then
    kill -TERM "$kill_target" 2>/dev/null || true
    sleep 1
    if kill -0 "$child_pid" 2>/dev/null; then
      kill -KILL "$kill_target" 2>/dev/null || true
    fi
  fi
  wait "$child_pid" 2>/dev/null || true
  child_pid=""
  child_kill_target=""
}

cleanup_all() {
  cleanup_child
  cleanup_caffeinate
}

on_interrupt() {
  echo
  echo "🌮 Closing the taco. Telling the agent to stop cooking..."
  cleanup_child
  cleanup_caffeinate
  exit 130
}

trap on_interrupt INT TERM HUP
trap cleanup_all EXIT

if command -v setsid >/dev/null 2>&1; then
  setsid /bin/bash -lc "$command_str" &
  child_pid=$!
  child_kill_target="-$child_pid"
else
  /bin/bash -lc "$command_str" &
  child_pid=$!
  child_kill_target="$child_pid"
fi

/usr/bin/caffeinate -dim -w "$child_pid" &
caffeinate_pid=$!

echo "🌮 Laptop Taco engaged"
echo
echo "Keeping your Mac awake while this runs:"
echo
echo "  ${command_str}"
echo
echo "PID: ${child_pid}"
echo "Started: ${start_clock}"
if [[ -n "$battery_pct" ]]; then
  echo "Battery: ${battery_pct}%"
  if (( battery_pct < 20 )); then
    echo "🌮 Taco warning: battery below 20%. Plug in or your agent may die mid-refactor."
  fi
fi
echo "Mode: cracked-open chaos"
echo
echo "Do not put a hot running laptop in a backpack. Seriously."
echo "Close the taco with Ctrl+C."
echo

wait "$child_pid"
child_exit=$?

cleanup_caffeinate

end_epoch="$(date +%s)"
elapsed=$(( end_epoch - start_epoch ))
if (( elapsed >= 3600 )); then
  runtime="$(( elapsed / 3600 ))h $(( (elapsed % 3600) / 60 ))m $(( elapsed % 60 ))s"
elif (( elapsed >= 60 )); then
  runtime="$(( elapsed / 60 ))m $(( elapsed % 60 ))s"
else
  runtime="${elapsed}s"
fi

if command -v osascript >/dev/null 2>&1; then
  osascript -e 'display notification "Your agent finished cooking 🌮" with title "Laptop Taco"' >/dev/null 2>&1 || true
fi

echo
if (( child_exit == 0 )); then
  echo "✅ Agent finished cooking"
else
  echo "🌮 Agent stopped cooking (non-zero exit)"
fi
echo "Runtime: ${runtime}"
echo "Exit code: ${child_exit}"
echo
echo "You may now close the taco."

exit "$child_exit"
