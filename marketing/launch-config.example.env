# Copy this to launch-config.env and fill in what you actually use.
# Every script checks its own variables and short-circuits gracefully
# if a service is missing — partial config is fine.

# --- Core ---
REPO_URL=https://github.com/YOUR_USERNAME/laptop-taco
PROJECT_NAME="Laptop Taco"
TAGLINE="For when your agent is cooking and you need to catch a bus."

# --- DEV.to (draft only — a human still hits Publish) ---
DEVTO_API_KEY=

# --- Hashnode (draft only) ---
HASHNODE_API_TOKEN=
HASHNODE_PUBLICATION_ID=

# --- Mastodon ---
MASTODON_INSTANCE=https://mastodon.social
MASTODON_ACCESS_TOKEN=

# --- Bluesky ---
BLUESKY_HANDLE=
BLUESKY_APP_PASSWORD=

# --- LinkedIn ---
# One-time: run ./marketing/scripts/get-linkedin-token.sh to capture these.
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=http://localhost:8080/callback
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_AUTHOR_URN=

# --- Threads (Meta) ---
THREADS_ACCESS_TOKEN=
THREADS_USER_ID=

# --- X / Twitter (requires paid Basic tier — ~$100/mo) ---
# If you don't want to pay, leave these blank. The README's Share section has
# a tweet-intent URL, and open-submit-tabs.sh opens it pre-filled.
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=

# --- Reddit (use carefully — one sub per launch) ---
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=
REDDIT_SUBREDDIT=SideProject
# Hard opt-in. The script refuses to post unless this is exactly "true".
REDDIT_AUTO_POST_OPT_IN=

# --- Webhooks (your own servers; pasted from each channel's integration UI) ---
DISCORD_WEBHOOK_URL=
SLACK_WEBHOOK_URL=

# --- GitHub release + repo metadata ---
# Fine-grained PAT scoped to this repo with Contents: write and Metadata: write.
GITHUB_TOKEN=
